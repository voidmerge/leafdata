{
  "$schema": "https://githubusercontent.com",
  "name": "leafdata",
  "scopeName": "source.leafdata",
  "fileTypes": ["leafdata"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#typed-cdata"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.leafdata",
          "match": "#.*$"
        },
        {
          "name": "comment.block.separator.leafdata",
          "match": "[:=,]+"
        },
        {
          "name": "comment.block.whitespace.leafdata",
          "match": "[ \\t\\r\\n]+"
        }
      ]
    },
    "typed-cdata": {
      "name": "meta.embedded.cdata.leafdata",
      "begin": "([a-zA-Z][a-zA-Z0-9]*)(@)(\")",
      "beginCaptures": {
        "1": { "name": "entity.name.type.leafdata" },
        "2": { "name": "keyword.operator.typed.leafdata" },
        "3": { "name": "keyword.operator.typed.leafdata" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "keyword.operator.typed.leafdata" }
      },
      "patterns": [
        {
          "name": "string.unquoted.cdata.leafdata",
          "match": "[^\"]+"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.null.leafdata",
          "match": "\\bnull\\b"
        },
        {
          "name": "constant.language.boolean.leafdata",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.float.leafdata",
      "match": "-?(0|[1-9][0-9]*)(\\.[0-9]+)?([eE][+-]?[0-9]+)?"
    },
    "strings": {
      "name": "string.quoted.double.leafdata",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.leafdata" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.leafdata" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.leafdata",
          "match": "\\\\([\"\\\\/bfnrt]|u[0-9a-fA-F]{4})"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.readwrite.leafdata",
      "match": "\\b[a-zA-Z$_][a-zA-Z0-9$_-]*\\b"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.dictionary.begin.leafdata",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.dictionary.end.leafdata",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.sequence.begin.leafdata",
          "match": "\\["
        },
        {
          "name": "punctuation.section.sequence.end.leafdata",
          "match": "\\]"
        }
      ]
    }
  }
}
